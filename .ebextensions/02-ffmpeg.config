commands:
  install_ffmpeg:
    test: "[ ! -x /usr/local/bin/ffmpeg ]"
    command: |
      set -e
      mkdir -p /opt/ffmpeg
      cd /tmp
      # John Van Sickle's static builds — official upstream-recommended
      # static ffmpeg for Linux. ~70MB compressed, includes libx264/AAC.
      # No package-manager dependencies, drops cleanly into /opt.
      curl -fsSL -o ffmpeg.tar.xz https://johnvansickle.com/ffmpeg/releases/ffmpeg-release-amd64-static.tar.xz
      tar -xf ffmpeg.tar.xz --strip-components=1 -C /opt/ffmpeg
      ln -sf /opt/ffmpeg/ffmpeg /usr/local/bin/ffmpeg
      ln -sf /opt/ffmpeg/ffprobe /usr/local/bin/ffprobe
      rm -f ffmpeg.tar.xz
      /usr/local/bin/ffmpeg -version | head -1
