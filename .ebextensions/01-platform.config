option_settings:
  aws:elasticbeanstalk:application:environment:
    NODE_ENV: production
  # Quiet the legacy Node platform's "static files via nginx" feature —
  # we route everything through the Next.js server because:
  #   - SSE streaming (/api/commentary) must reach Node, not nginx
  #   - CloudFront in front already caches /_next/static/*
  aws:elasticbeanstalk:environment:proxy:
    ProxyServer: nginx
