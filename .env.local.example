# Required. Get yours from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Required. Get yours from https://console.deepgram.com/
# Used for live speech recognition with speaker diarization.
DEEPGRAM_API_KEY=

# Optional — only for the Retake OpenAI Realtime voice engine.
# Needs an OpenAI account with Realtime API access + billing.
# Get yours from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional — selects the Retake mock-interview engine:
#   "openai" → OpenAI Realtime voice (requires OPENAI_API_KEY above)
#   unset / anything else → Aura TTS + Deepgram STT + Claude (default)
# Must be NEXT_PUBLIC_ (read in the browser).
NEXT_PUBLIC_RETAKE_ENGINE=
