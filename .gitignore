# Not useful in version control; dev.log can grow to multi-MB.
dev.log
envcheck.log

# env files (all local environment files)
.env
.env.local
.env*.local

# vercel
.vercel

# elastic beanstalk
.elasticbeanstalk/
*.zip

# Local deploy staging — bundles, secrets-bearing option JSON,
# version pointer. NEVER commit; everything in here is regenerated
# on demand by .deploy/package.ps1 + the deploy CLI calls.
.deploy/

# typescript
*.tsbuildinfo
next-env.d.ts

